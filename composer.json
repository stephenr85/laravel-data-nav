{
    "name": "rushing/laravel-data-nav",
    "description": "Domain-agnostic navigation spine for Laravel. A polymorphic NavItem interface with SchemaIdentity DTO implementations (static NavLink + invocable-backed InvokableNavItem) and a NavTree, resolved server-side through a laravel-popcorn invocable. Consumable by both Inertia/React (JSON) and Blade (array) hosts. Emits no HTML. Part of the laravel-data-* family.",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": "^8.3",
        "illuminate/contracts": "^12.0",
        "illuminate/http": "^12.0",
        "illuminate/support": "^12.0",
        "rushing/laravel-data-schemas": "dev-main",
        "rushing/laravel-popcorn": "dev-main",
        "spatie/laravel-data": "^4.0",
        "spatie/laravel-package-tools": "^1.16"
    },
    "repositories": [
        {
            "type": "git",
            "url": "https://github.com/stephenr85/laravel-data-schemas.git"
        },
        {
            "type": "git",
            "url": "https://github.com/stephenr85/laravel-popcorn.git"
        }
    ],
    "require-dev": {
        "orchestra/testbench": "^10.0",
        "pestphp/pest": "^3.0",
        "pestphp/pest-plugin-laravel": "^3.0",
        "laravel/pint": "^1.0"
    },
    "autoload": {
        "psr-4": {
            "Rushing\\DataNav\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Rushing\\DataNav\\Tests\\": "tests/"
        }
    },
    "extra": {
        "branch-alias": {
            "dev-main": "1.0.x-dev"
        },
        "laravel": {
            "providers": [
                "Rushing\\DataNav\\ServiceProvider"
            ]
        }
    },
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "scripts": {
        "pint": "@php -d memory_limit=512M vendor/bin/pint"
    }
}
